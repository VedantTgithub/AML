# ── Environment ────────────────────────────────
ENV=dev

# ── Kafka ──────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_INTERNAL_BOOTSTRAP_SERVERS=clarity-kafka:29092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT

# ── Topics ─────────────────────────────────────
TOPIC_TRANSACTIONS_RAW=clarity.transactions.raw
TOPIC_ENTITIES_RESOLVED=clarity.entities.resolved
TOPIC_ALERTS_GENERATED=clarity.alerts.generated
TOPIC_GRAPH_UPDATES=clarity.graph.updates
TOPIC_REPORTS_FIU=clarity.reports.fiu
TOPIC_DLQ_TRANSACTIONS=clarity.dlq.transactions
TOPIC_SANCTIONS_UPDATES=clarity.sanctions.updates

# ── Storage ────────────────────────────────────
BRONZE_PATH=./data/lake/bronze
SILVER_PATH=./data/lake/silver
GOLD_PATH=./data/lake/gold

# ── Snowflake ──────────────────────────────────
SNOWFLAKE_ACCOUNT=your_trial_account
SNOWFLAKE_DATABASE=CLARITY_DEV
SNOWFLAKE_WAREHOUSE=CLARITY_WH_XS
SNOWFLAKE_SCHEMA=AML
SNOWFLAKE_ROLE=CLARITY_DEV_ROLE